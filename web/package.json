{
  "name": "message-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:raw": "cp -r src dist",
    "verify": "node scripts/verify-build.mjs",
    "verify:cdn": "node scripts/verify-build.mjs --check-cdn --verbose",
    "preview": "wrangler pages dev ./src",
    "typecheck": "tsc --noEmit",
    "test:crypto": "node --experimental-strip-types --experimental-transform-types --test src/shared/crypto/__tests__/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
